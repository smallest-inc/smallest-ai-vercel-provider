{
  "name": "smallestai-vercel-provider",
  "version": "1.0.0",
  "description": "Vercel AI SDK provider for Smallest AI — ultra-fast TTS (Lightning) and STT (Pulse)",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.1",
    "@ai-sdk/provider-utils": "^5.0.2",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "ai": "^7.0.9",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-sdk",
    "vercel",
    "smallest-ai",
    "tts",
    "stt",
    "text-to-speech",
    "speech-to-text",
    "lightning",
    "pulse"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smallest-inc/smallest-ai-vercel-provider.git"
  },
  "homepage": "https://smallest.ai",
  "author": "Smallest AI <support@smallest.ai>",
  "publishConfig": {
    "access": "public"
  }
}
