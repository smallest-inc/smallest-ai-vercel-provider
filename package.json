{
  "name": "smallestai-vercel-provider",
  "version": "0.1.2",
  "description": "Vercel AI SDK provider for Smallest AI — ultra-fast TTS (Lightning) and STT (Pulse)",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@ai-sdk/provider-utils": "^3.0.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-sdk",
    "vercel",
    "smallest-ai",
    "tts",
    "stt",
    "text-to-speech",
    "speech-to-text",
    "lightning",
    "pulse"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/smallest-inc/smallest-ai-vercel-provider"
  },
  "homepage": "https://smallest.ai",
  "author": "Smallest AI <support@smallest.ai>",
  "publishConfig": {
    "access": "public"
  }
}
